# Required: Path to your Arma Reforger server.json
SERVER_CONFIG_PATH=/path/to/your/server.json

# Required: RCON password (must match rcon.password in server.json)
RCON_PASSWORD=your_rcon_password

# Optional defaults
# RCON_HOST=host.docker.internal
# RCON_PORT=29999
# SERVER_CONTAINER=arma-reforger
# MODE=full
